{
  "name": "wasiai-a2a",
  "version": "0.1.0",
  "type": "module",
  "description": "A2A Protocol — Agent discovery, composition, and orchestration service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/static && cp -r src/static/. dist/static/",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.101.1",
    "fastify": "^5.8.4",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ferrosasfp/wasiai-a2a.git"
  },
  "keywords": [
    "ai",
    "agents",
    "a2a",
    "discovery",
    "orchestration"
  ],
  "author": "WasiAI",
  "license": "MIT"
}
