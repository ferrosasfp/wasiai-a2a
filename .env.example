# WasiAI A2A Protocol — Environment Variables
# Copiar a .env y completar con valores reales

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# CORS — Cross-Origin Resource Sharing
# En development (NODE_ENV=development o ausente) se permite * (todos los origins).
# En production esta var es OBLIGATORIA: CSV de origins permitidos.
# Si queda vacía en production, TODOS los cross-origin requests son bloqueados
# (fail-secure) y el servidor loguea un warning al startup.
# Ejemplo: CORS_ALLOWED_ORIGINS=https://app.wasiai.io,https://wasiai.io
# ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────────────────────────
# Dashboard Admin Token (opt-in) — protege /dashboard/api/*
# - unset → dev abierto (en production los endpoints responden 503).
# - set   → header `X-Admin-Token: <valor>` requerido en /dashboard/api/*.
# La página HTML pública GET /dashboard NO requiere token.
# ─────────────────────────────────────────────────────────────
DASHBOARD_ADMIN_TOKEN=

# ─────────────────────────────────────────────────────────────
# Internal Forward-Key Auth (WKH-65) — OPTIONAL
# Shared secret validated by /compose and /orchestrate when an internal
# caller (e.g. wasiai-v2 thin proxy on Vercel) forwards a request via
# the x-wasiai-forward-key header. Defense-in-depth on top of x-payment /
# x-a2a-key.
#
# Behavior:
#   - UNSET or empty → middleware NOT mounted; external clients keep
#     authenticating only via x-payment / x-a2a-key (backward compatible).
#   - SET            → if x-wasiai-forward-key header is present it must
#     match exactly (timingSafeEqual). Mismatch → 401 INVALID_FORWARD_KEY.
#     Header absent → passthrough to the next preHandler (still requires
#     x-payment or x-a2a-key downstream).
#
# Generate with: openssl rand -hex 32
# NEVER commit the real value. Rotate by updating the env var on Railway
# AND on the wasiai-v2 proxy simultaneously.
# ─────────────────────────────────────────────────────────────
WASIAI_V2_FORWARD_KEY=

# ─────────────────────────────────────────────────────────────
# Passport-only inbound enforcement (WKH-69) — OPTIONAL
# Opt-in guard that rejects x402 requests not originating from a
# Kite Passport session. Backward compat is preserved by default.
#
# Behavior:
#   - UNSET / empty / any value other than literal 'true' → middleware NOT
#     mounted. Both EOA and Passport requests are accepted (default).
#   - SET to literal 'true' (case-sensitive) → routes that mount
#     `requirePassport()` will reject inbound requests without
#     `x-passport-session: true` header with HTTP 403 PASSPORT_REQUIRED.
#
# Activation requires TWO steps:
#   1. Set this env var to 'true' on the deployment.
#   2. Edit the route handler to add `requirePassport()` AFTER
#      `requirePayment(...)` in the preHandler array. See
#      doc/passport-onboarding.md § "Opt-in Passport-only enforcement".
#
# Order matters: requirePayment MUST run first because it sets
# request.paymentOrigin from the header. requirePassport reads it.
#
# Pre-merge note (CD-WKH69-1): leave this UNSET in production until the
# post-merge smoke-test confirms real Passport signature shape works.
# ─────────────────────────────────────────────────────────────
PASSPORT_REQUIRE_INBOUND=

# ─────────────────────────────────────────────────────────────
# Supabase — PostgreSQL persistencia
# Runtime var name: SUPABASE_SERVICE_KEY (NO SUPABASE_SERVICE_ROLE_KEY,
#   que aparecía en docs legacy — el código usa SUPABASE_SERVICE_KEY).
# SERVICE_KEY: usar service_role key (NO la anon key)
# Obtener en: Supabase Dashboard → Settings → API
# Dev project: bdwvrwzvsldephfibmuu.supabase.co
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://bdwvrwzvsldephfibmuu.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────
# Migration Pre-flight (WKH-78) — shadow DB connection string
# ─────────────────────────────────────────────────────────────
# Postgres connection URL for the SHADOW database used by
# `npm run migrate:preflight -- migrations/<file>.sql`.
#
# The pre-flight script connects to this DB, wraps the migration
# in BEGIN ... ROLLBACK (never COMMIT), and reports timing + errors.
# It NEVER mutates this DB permanently.
#
# IMPORTANT — point this at the DEV/SHADOW project (bdwvrwzvsldephfibmuu),
# NEVER at the prod project (caldzjhjgctpgodldqav). The script cannot
# tell them apart by URL alone (CD-1 in WKH-78 work-item).
#
# Format: postgres://USER:PASS@HOST:PORT/DB
# Get from: Supabase Dashboard → DEV project → Settings → Database
#           → Connection string (URI mode), or use the pooler URL.
# Leave EMPTY to skip the shadow dry-run (analyzer-only mode).
# ─────────────────────────────────────────────────────────────
SHADOW_DATABASE_URL=

# DATABASE_URL is read by `migrate-preflight.mjs --post-apply` for
# the integrity check. Same format as SHADOW_DATABASE_URL. Leave
# empty unless running the post-apply step manually.
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Kite Chain — KiteAI Testnet (Ozone, Chain ID: 2368)
# RPC publico, no requiere API key.
# Obtener KITE tokens de test: https://faucet.gokite.ai
# Explorer: https://testnet.kitescan.ai
# ─────────────────────────────────────────────────────────────
KITE_RPC_URL=https://rpc-testnet.gokite.ai/

# ─── Kite Network Selection (068) ──────────────────────────
# Selecciona Kite chain para inbound x402 payments. Activación requiere:
#   1. Setear `KITE_NETWORK=mainnet`.
#   2. Setear `KITE_MAINNET_RPC_URL=https://rpc.gokite.ai/`.
#   3. Override opcional de `X402_PAYMENT_TOKEN` / `X402_EIP712_DOMAIN_NAME`
#      / `X402_TOKEN_SYMBOL` si querés algo distinto al USDC.e canonical.
# Default: testnet (preserva comportamiento WKH-29).
#
# Mainnet defaults (sin overrides):
#   - chainId: 2366
#   - Token: USDC.e at 0x7aB6f3ed87C42eF0aDb67Ed95090f8bF5240149e
#   - EIP-712 domain: USDC
#   - Symbol: USDC.e
#   - Explorer: https://kitescan.ai
KITE_NETWORK=testnet
KITE_MAINNET_RPC_URL=

# ─── Chain Adapter Selection ────────────────────────────────
# Selects which adapter bundle to load at startup.
# Currently supported: kite-ozone-testnet
# (legacy single-chain var — see WASIAI_A2A_CHAINS below for multi-chain support)
WASIAI_A2A_CHAIN=kite-ozone-testnet

# ─── Multi-chain registry (WKH-MULTICHAIN / 086) ────────────────────────
# CSV of chains to initialize at startup. Default = first entry in the CSV.
# Supported slugs: kite-ozone-testnet, kite-mainnet, avalanche-fuji,
# avalanche-mainnet.
#
# Backward-compat: if this var is absent, WASIAI_A2A_CHAIN (legacy single-chain)
# is used. If both vars are set, WASIAI_A2A_CHAINS wins and a WARNING is logged
# at startup ([Registry] WARNING: both WASIAI_A2A_CHAINS and WASIAI_A2A_CHAIN
# are set. Using WASIAI_A2A_CHAINS=<csv> — singular ignored).
#
# Chain selection per-request priority (CD-14, DT-1+DT-A):
#   1. header `x-payment-chain: <slug | chainId>` (e.g. `avalanche-fuji` or `43113`)
#   2. agent manifest payment.chain (delegated to upstream caller — see
#      doc/architecture/MULTI-CHAIN.md §3)
#   3. default chain (first entry in WASIAI_A2A_CHAINS)
#
# NOTE: WASIAI_A2A_CHAINS controls which chains the gateway accepts for
# inbound A2A_KEY budget debit. It is INDEPENDENT of WASIAI_DOWNSTREAM_NETWORK
# below (WKH-55), which controls the chain used for USDC outbound signatures
# against external agents. Both paths coexist independently.
WASIAI_A2A_CHAINS=kite-ozone-testnet

# ─── Avalanche facilitator override (optional) ──────────────────────────
# Facilitator URL used by AvalanchePaymentAdapter.verify() / .settle() for
# both Fuji (43113) and C-Chain mainnet (43114). The facilitator routes per
# chain internally via the canonical x402 body (`accepted.network`).
# Resolution order:
#   1. AVALANCHE_FACILITATOR_URL (this var)
#   2. WASIAI_FACILITATOR_URL (shared with downstream)
#   3. hardcoded https://wasiai-facilitator-production.up.railway.app
# Leave unset to use the default. PROHIBIDO mode `pieverse` for Avalanche
# (CD-15) — canonical x402 only.
AVALANCHE_FACILITATOR_URL=

# Block explorer URL for dashboard links (falls back to KITE_EXPLORER_URL, then testnet.kitescan.ai)
CHAIN_EXPLORER_URL=https://testnet.kitescan.ai

# ─── Kite Service Provider (x402) ──────────────────────────
# Wallet address on Kite testnet que recibe los pagos (OBLIGATORIO)
KITE_WALLET_ADDRESS=0xf432baf1315ccDB23E683B95b03fD54Dd3e447Ba

# Chain-agnostic alias for payment wallet (falls back to KITE_WALLET_ADDRESS)
PAYMENT_WALLET_ADDRESS=

# Facilitator protocol. Default 'pieverse' (current production path).
# Set to 'x402' to route verify/settle via the canonical x402 spec against
# the WasiAI self-hosted facilitator (EIP-3009 TransferWithAuthorization).
# Use 'x402' as a fallback when Pieverse is unavailable.
KITE_FACILITATOR_MODE=pieverse

# Facilitator base URL. If unset, defaults by mode:
#   pieverse → https://facilitator.pieverse.io
#   x402     → https://wasiai-facilitator-production.up.railway.app
KITE_FACILITATOR_URL=https://facilitator.pieverse.io

# Optional: resource URL stamped onto x402 requests (mode=x402 only).
# X402_RESOURCE_URL=https://wasiai.ai/pay

# Payment amount in wei (default en codigo: 1000000000000000000 = 1 Test USDT)
# Solo necesario si se quiere sobreescribir el default
KITE_PAYMENT_AMOUNT=1000000000000000000

# Merchant name shown to paying agents
KITE_MERCHANT_NAME=WasiAI

# ─── x402 Token Configuration (PYUSD) ─────────────────────
# ERC-20 token address for x402 payments on Kite testnet.
# Default: PYUSD 0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9 (canonical Kite testnet, chain 2368)
X402_PAYMENT_TOKEN=0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9

# EIP-712 domain name used in transferWithAuthorization signatures
X402_EIP712_DOMAIN_NAME=PYUSD

# EIP-712 domain version
X402_EIP712_DOMAIN_VERSION=1

# Token symbol reported in 402 Payment Required responses
X402_TOKEN_SYMBOL=PYUSD

# ─── Agent Blocklist ────────────────────────────────────────
# Comma-separated slugs to exclude from discovery (mock/broken agents)
AGENT_BLOCKLIST=dataarbitrageagent

# ─────────────────────────────────────────────────────────────
# Gasless EIP-3009 (WKH-29) — testnet only (PYUSD)
# Relayer: https://gasless.gokite.ai/testnet
# Token: PYUSD 0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9 (chain 2368)
# ─────────────────────────────────────────────────────────────
GASLESS_ENABLED=false
OPERATOR_PRIVATE_KEY=0xYourOperatorPrivateKey

# ─────────────────────────────────────────────────────────────
# WKH-35 — Deposit verification (budget prepago)
# Recipient esperado del depósito por chain. Si no se setea, cae al
# operator address derivado de OPERATOR_PRIVATE_KEY (DT-2).
A2A_DEPOSIT_TREASURY_KITE=
A2A_DEPOSIT_TREASURY_AVALANCHE=
A2A_DEPOSIT_TREASURY_BASE=

# Confirmaciones mínimas antes de acreditar (DT-3).
# Global fallback + override por chain. Default 1 (testnet); 3+ recomendado en mainnet.
A2A_DEPOSIT_MIN_CONFIRMATIONS=1
A2A_DEPOSIT_MIN_CONFIRMATIONS_KITE=
A2A_DEPOSIT_MIN_CONFIRMATIONS_AVALANCHE=
A2A_DEPOSIT_MIN_CONFIRMATIONS_BASE=

# ─────────────────────────────────────────────────────────────
# Gasless Pricing (WKH-59) — protección contra drain del operator
# ─────────────────────────────────────────────────────────────
# Rate de conversión PYUSD → USD usado por POST /gasless/transfer para
# convertir `body.value` (wei) en USD antes del debit del A2A key.
# PYUSD es stablecoin pegada 1:1 USD por diseño; este override existe
# para escenarios de depeg temporal o tokens test con rate distinto.
# Range válido [0, 100]. Fuera de rango / no parseable → fallback 1.0
# con console.warn. Default: 1.0
PYUSD_USD_RATE=1.0

# Cap GLOBAL para POST /gasless/transfer: el monto máximo en USD que
# una sola request puede mover desde el operator wallet, INDEPENDIENTE
# del budget de la key. Defensa-en-profundidad contra keys con budget
# alto que intenten drains masivos. Range válido (0, 10000]. Default: 10
GASLESS_DEFAULT_CAP_USD=10

# ─────────────────────────────────────────────────────────────
# Schema Transform HMAC (WKH-60 SEC-RCE-1) — defense-in-depth
# ─────────────────────────────────────────────────────────────
# HMAC-SHA256 key para firmar `transform_fn` antes de persistir en
# kite_schema_transforms y verificar al leer del cache L2. Protege
# contra DB tampering: una row con transform_fn modificado por un
# rogue admin se rechaza en cache miss + warn (degraded mode).
#
# Generar con: openssl rand -hex 32  (32 bytes hex = 64 chars)
# OBLIGATORIO en producción. Sin esta var → degraded mode con
# warn-once por proceso (HMAC verification skipped).
SCHEMA_TRANSFORM_HMAC_KEY=

# ─────────────────────────────────────────────────────────────
# LLM — Anthropic (Claude Sonnet for /orchestrate planning)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─────────────────────────────────────────────────────────────
# Agent Card Generation
# ─────────────────────────────────────────────────────────────
# Override the base URL for agent card generation (auto-detected from request if omitted)
BASE_URL=

# ─────────────────────────────────────────────────────────────
# Rate Limiting (tiered)
# Global default applies to all routes not exempt or overridden.
# /health, /gasless/status, /.well-known → exempt (rateLimit: false)
# /orchestrate, /compose → RATE_LIMIT_ORCHESTRATE_MAX (heavy, costs money)
# /auth/agent-signup → RATE_LIMIT_SIGNUP_MAX (prevents key spam)
# ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_ORCHESTRATE_MAX=10
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────────────────────
# Timeouts & Backpressure
# ─────────────────────────────────────────────────────────────
TIMEOUT_ORCHESTRATE_MS=120000
# WKH-65: bumped 120000 → 180000 default to absorb wasiai-v2 thin-proxy
# Vercel → Railway network hop. Override here for stricter limits.
TIMEOUT_COMPOSE_MS=180000
BACKPRESSURE_MAX=20
SHUTDOWN_GRACE_MS=30000
# DISCOVERY_REGISTRY_TIMEOUT_MS: timeout HTTP per-registry (ms) del fanout de
# discovery. Variable ACTIVA, consumida en src/services/discovery.ts. Default 5000.
DISCOVERY_REGISTRY_TIMEOUT_MS=5000

# ─────────────────────────────────────────────────────────────
# Circuit Breakers
# ─────────────────────────────────────────────────────────────
# Anthropic LLM circuit breaker
CB_ANTHROPIC_FAILURES=5
CB_ANTHROPIC_WINDOW_MS=60000
CB_ANTHROPIC_COOLDOWN_MS=30000

# Per-registry circuit breaker
CB_REGISTRY_FAILURES=5
CB_REGISTRY_WINDOW_MS=60000
CB_REGISTRY_COOLDOWN_MS=30000

# ─────────────────────────────────────────────────────────────
# MCP Server (WKH-MCP-X402)
# ─────────────────────────────────────────────────────────────
# Token MCP — SHA-256 hash de un bearer compartido con el cliente (ej: Claude Managed Agent).
# Generar con: echo -n "mi-token-secreto" | sha256sum
MCP_TOKEN_HASH=

# Alternativa multi-token: JSON array de hashes SHA-256 (hex64 cada uno).
# Ejemplo: ["abc123...","def456..."]
MCP_TOKENS=

# Rate limit por token MCP (independiente del global).
MCP_RATE_LIMIT_MAX=30
MCP_RATE_LIMIT_WINDOW_MS=60000

# Timeout del fetch de pay_x402 (ms).
MCP_PAY_TIMEOUT_MS=30000

# SSRF allowlist — CSV de hostnames permitidos para gatewayUrl en pay_x402 /
# get_payment_quote. Si vacío, se acepta cualquier host público (los privados
# y literales tipo localhost/*.local siempre se rechazan). Ejemplo:
#   MCP_GATEWAY_ALLOWLIST=gw.example.com,facilitator.pieverse.io
MCP_GATEWAY_ALLOWLIST=

# SSRF allowlist (WKH-62) — CSV de hostnames permitidos para los endpoints
# de registries (`discoveryEndpoint` / `invokeEndpoint`) y los runtime
# fetches de discoveryService. Hosts en la lista bypassean la verificación
# de IP privada. Los literales `localhost` y `*.local` NUNCA son
# bypasseables. Default: vacío (sin allowlist; todos los rangos privados
# bloqueados).
DISCOVERY_SSRF_ALLOWLIST=

# Guard por defecto del monto máximo en wei aceptado por pay_x402 cuando el
# input no provee `maxAmountWei`. Protege contra gateways que pidan un pago
# arbitrariamente grande. Dejar vacío para deshabilitar el guard por defecto.
MCP_MAX_AMOUNT_WEI_DEFAULT=

# ─────────────────────────────────────────────────────────────
# Protocol Fee (WKH-44) — el gateway cobra un % del budget de /orchestrate
# como fee del protocolo. El operator (OPERATOR_PRIVATE_KEY) firma EIP-712 y
# transfiere KXUSD desde SU wallet hacia WASIAI_PROTOCOL_FEE_WALLET. Si la
# var está vacía, el fee NO se transfiere (log warn, orchestrate continúa).
# IMPORTANTE: la wallet del operator debe tener saldo suficiente de KXUSD.
# ─────────────────────────────────────────────────────────────
WASIAI_PROTOCOL_FEE_WALLET=

# Rate del fee en decimal (default 0.01 = 1%). Rango válido [0.0, 0.10].
# Fuera de rango o no parseable → fallback 0.01 con console.error.
# Se lee por request; un restart de Railway basta para aplicar un nuevo valor.
PROTOCOL_FEE_RATE=0.01

# ============================================================
# Downstream x402 — Avalanche (WKH-55 + 068 mainnet support)
# ============================================================
# Habilita pago downstream USDC al invocar agentes wasiai-v2 que declaren
# payment.method=x402 + payment.chain=avalanche en su agent card.
# Default: ausente (skip). Solo el valor literal 'true' lo activa.
WASIAI_DOWNSTREAM_X402=

# ─── Network Selection (068) ────────────────────────────────
# Selecciona la chain target para downstream payments.
#   - `fuji` (default): testnet, chainId 43113.
#   - `avalanche-mainnet`: mainnet, chainId 43114.
#
# Activación mainnet requiere:
#   1. Setear `WASIAI_DOWNSTREAM_NETWORK=avalanche-mainnet`.
#   2. Setear `AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc`.
#   3. Fundear el operator wallet (OPERATOR_PRIVATE_KEY) con USDC en
#      Avalanche C-Chain mainnet (verifiable on snowtrace.io).
#   4. Opcional: `AVALANCHE_USDC_ADDRESS` para override del canonical Circle.
#
# Default `fuji` preserva el comportamiento histórico WKH-55.
WASIAI_DOWNSTREAM_NETWORK=fuji

# RPC publico Avalanche Fuji testnet (chainId 43113)
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# RPC publico Avalanche C-Chain mainnet (chainId 43114) — sólo se lee cuando
# `WASIAI_DOWNSTREAM_NETWORK=avalanche-mainnet`.
AVALANCHE_RPC_URL=

# Direccion del token USDC en Fuji (default canonical Circle USDC).
# Si esta ausente, usa 0x5425890298aed601595a70AB815c96711a31Bc65 con warn-once.
FUJI_USDC_ADDRESS=

# Direccion del token USDC en Avalanche C-Chain mainnet (default canonical
# Circle USDC). Si esta ausente, usa 0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E
# con warn-once. Sólo se lee cuando WASIAI_DOWNSTREAM_NETWORK=avalanche-mainnet.
AVALANCHE_USDC_ADDRESS=

# EIP-712 version override para USDC (default '2'). Mismo Circle USDC ABI
# en ambas chains; el override por-chain se respeta sobre el global.
FUJI_USDC_EIP712_VERSION=
AVALANCHE_USDC_EIP712_VERSION=

# ============================================================
# Base — inbound x402 path (WKH-104 / BASE-01)
# ============================================================
# Habilita el adapter Base (chainId 8453 mainnet, 84532 sepolia testnet)
# para inbound x402 USDC EIP-3009 sobre wasiai-a2a. Para activarlo, agregar
# 'base-sepolia' o 'base-mainnet' al CSV WASIAI_A2A_CHAINS arriba.
# Default conservador (CD-4): testnet.

# Selecciona la red Base activa para el adapter (standalone/factory).
# Valores: 'mainnet' | 'testnet' (default 'testnet'). Cualquier otro valor
# es ignorado con console.warn y defaultea a 'testnet'.
BASE_NETWORK=testnet

# RPC público Base Sepolia (chainId 84532) — testnet, default
# https://sepolia.base.org. Override si usás un provider dedicado (Alchemy,
# Infura, QuickNode).
BASE_TESTNET_RPC_URL=https://sepolia.base.org

# RPC público Base Mainnet (chainId 8453) — sólo se lee cuando
# BASE_NETWORK=mainnet. Default https://mainnet.base.org.
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Dirección USDC en Base Sepolia (default canonical Circle USDC test).
# Si ausente, usa 0x036CbD53842c5426634e7929541eC2318f3dCF7e con warn-once.
BASE_SEPOLIA_USDC_ADDRESS=

# Dirección USDC en Base Mainnet (default canonical Circle USDC).
# Si ausente, usa 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913 con warn-once.
BASE_MAINNET_USDC_ADDRESS=

# EIP-712 version override para USDC en Base. Default '2' en ambas redes
# (verified onchain by WKH-105 sibling Dev, 2026-05-19). Sólo setear si
# alguna deployment futura cambia la version. Per-network porque la
# deployment puede diferir (CD-3 escape hatch).
BASE_SEPOLIA_USDC_EIP712_VERSION=
BASE_MAINNET_USDC_EIP712_VERSION=

# Facilitator URL override para Base (verify/settle). Resolución (DT-3):
#   1. BASE_FACILITATOR_URL (esta var — override absoluto, testing)
#   2. CDP_FACILITATOR_URL (placeholder BASE-01, real en BASE-02)
#   3. WASIAI_FACILITATOR_URL (compartido con Avalanche)
#   4. hardcoded https://wasiai-facilitator-production.up.railway.app
BASE_FACILITATOR_URL=

# CDP Facilitator URL (Coinbase Bazaar / x402.org/facilitator).
#
# Resolution order — see src/adapters/base/payment.ts:163-170 + src/lib/cdp-selector.ts:
#   1. BASE_FACILITATOR_URL (absolute override, testing)
#   2. CDP_FACILITATOR_URL (THIS var — wired by WKH-106 BASE-03 for
#      Coinbase Bazaar integration)
#   3. WASIAI_FACILITATOR_URL (shared with Avalanche)
#   4. hardcoded https://wasiai-facilitator-production.up.railway.app
#
# WKH-106 (BASE-03) behavior:
#   - When SET on a Base chain settle (chainKey starts with 'base-'),
#     the compose service routes the settle call to this URL.
#   - When UNSET, compose preserves the existing facilitator path
#     (AC-5 no-regression).
#   - The selector is Base-ONLY (CD-5) — Kite + Avalanche settles
#     are NEVER affected by this var.
#   - The compose layer logs the decision as:
#       [Compose] Base settle facilitator selector — chainKey=<X> selected=<Y> cdpEnvSet=<Z>
#     This line is greppable in production for AC-2 / AC-5 observability.
#
# Production value (when ready): https://x402.org/facilitator
CDP_FACILITATOR_URL=

# Placeholder CDP API key — sin uso real en BASE-01, reservado para
# integraciones futuras (Paymaster, OnchainKit). NO ponerlo en logs.
CDP_API_KEY=
