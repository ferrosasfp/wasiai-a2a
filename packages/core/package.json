{
  "name": "@wasiai/a2a-core",
  "version": "0.1.0",
  "description": "Core interfaces and orchestration logic for WasiAI A2A Protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "ai",
    "agents",
    "a2a",
    "discovery",
    "orchestration",
    "wasiai",
    "kite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ferrosasfp/wasiai-a2a.git",
    "directory": "packages/core"
  }
}
